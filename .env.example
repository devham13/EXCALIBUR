# Cursor Cloud / self-hosted worker
CURSOR_API_KEY=

# Public site (production: PUBLIC_SITE_URL — см. shared/production-site.md)
WP_SITE_URL=
WP_ADMIN_URL=
PUBLIC_SITE_URL=PUBLIC_SITE_URL

# Excalibur BLOG publish
EXCALIBUR_BLOG_ALLOW_PUBLISH=no
EXCALIBUR_TOPIC_ID=
