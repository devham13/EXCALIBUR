# FTP (WP publish script)
FTP_HOST=
FTP_PORT=21
FTP_USER=
FTP_PASSWORD=

# Optional SSH if you extend publish later
SSH_HOST=
SSH_PORT=22
SSH_USER=
SSH_PASSWORD=

# MCP tokens via env interpolation in mcp.json — never commit real values
# MCP_KV_TOKEN=
