# Cursor Cloud / self-hosted worker
CURSOR_API_KEY=

# Excalibur BLOG — project-scoped (не конфликтует с другими проектами в shared Secrets)
EXCALIBUR_PUBLIC_SITE_URL=
EXCALIBUR_EXCALIBUR_SITE_BRAND=
EXCALIBUR_BLOG_ALLOW_PUBLISH=no
EXCALIBUR_TOPIC_ID=
EXCALIBUR_PROJECT_ROOT=

# Legacy (миграция; не использовать в multi-project Secrets)
# EXCALIBUR_PUBLIC_SITE_URL=
# WP_SITE_URL=

# FTP (WP publish script)
FTP_HOST=
FTP_PORT=21
FTP_USER=
FTP_PASSWORD=

# Optional SSH if you extend publish later
SSH_HOST=
SSH_PORT=22
SSH_USER=
SSH_PASSWORD=

# MCP tokens via env interpolation in mcp.json — never commit real values
# MCP_KV_TOKEN=
