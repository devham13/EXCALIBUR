 {
 "@type": "FAQPage",
 "@id": "$EXCALIBUR_PUBLIC_SITE_URL/blog/podklyuchenie-mcp-cursor/#faq",
 "mainEntity": [
 {
 "@type": "Question",
 "name": "Как подключить MCP к Cursor?",
 "acceptedAnswer": {
 "@type": "Answer",
 "text": "Откройте Settings (Ctrl+Shift+J) → Tools & MCP → \"Add to Cursor\" у нужного сервера. Либо создайте ~/.cursor/mcp.json или .cursor/mcp.json, добавьте блок mcpServers, сохраните валидный JSON и перезапустите Cursor. Проверьте активный статус сервера и вызовите tool тестовым prompt в Agent."
 }
 },
 {
 "@type": "Question",
 "name": "Где файл mcp.json на Windows?",
 "acceptedAnswer": {
 "@type": "Answer",
 "text": "Глобально: C:\\Users\\<ваш_логин>\\.cursor\\mcp.json. Для одного проекта: папка .cursor в корне репозитория. При совпадении имён сервера приоритет у проектного файла."
 }
 },
 {
 "@type": "Question",
 "name": "Почему MCP сервер красный и не подключается?",
 "acceptedAnswer": {
 "@type": "Answer",
 "text": "Откройте Output → MCP Logs. Частые причины: битый JSON, нет Node/npx (ENOENT), неверный API key в env или headers. Исправьте конфиг, перезапустите Cursor и снова проверьте логи."
 }
 },
 {
 "@type": "Question",
 "name": "Нужно ли каждый раз подтверждать вызов tool?",
 "acceptedAnswer": {
 "@type": "Answer",
 "text": "По умолчанию да – это защита. После тестов добавьте доверенные tools в allowlist или permissions.json; в Cursor 3.6+ настройте Auto-review в Settings → Agents → Run Mode."
 }
 },
 {
 "@type": "Question",
 "name": "Сколько MCP-серверов можно включить?",
 "acceptedAnswer": {
 "@type": "Answer",
 "text": "Формально много; в 2026 dynamic context снижает нагрузку от большого числа tools. На практике держите 3–5 серверов под реальные задачи, а не весь каталог cursor.directory."
 }
 },
 {
 "@type": "Question",
 "name": "Чем MCP отличается от Skills в Cursor?",
 "acceptedAnswer": {
 "@type": "Answer",
 "text": "MCP подключает внешние программы и API (браузер, GitHub, CMS). Skills – готовые инструкции и сценарии внутри редактора. Используйте оба: Skills для стиля работы агента, MCP для доступа к сервисам."
 }
 },
 {
 "@type": "Question",
 "name": "MCP в Cursor или Make/n8n – что выбрать?",
 "acceptedAnswer": {
 "@type": "Answer",
 "text": "MCP усиливает Agent в IDE при разработке и контенте. Make и n8n запускают сценарии по расписанию и webhook без вашего участия. Связка: Cursor готовит → Make публикует; подробнее в статье про n8n и ИИ-агентов."
 }
 }
 ]
 },
 {
