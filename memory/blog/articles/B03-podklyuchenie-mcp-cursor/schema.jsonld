 "step": [
 {
 "@type": "HowToStep",
 "position": 1,
 "name": "Откройте Tools & MCP",
 "text": "Обновите Cursor до актуальной версии. Откройте Settings (Ctrl+Shift+J на Windows) → раздел Tools & MCP.",
 "url": "$EXCALIBUR_PUBLIC_SITE_URL/blog/podklyuchenie-mcp-cursor/#one-click"
 },
 {
 "@type": "HowToStep",
 "position": 2,
 "name": "Выберите способ подключения",
 "text": "Способ A: нажмите \"Add to Cursor\" у нужного сервера в Marketplace или на cursor.directory. Способ B: создайте ~/.cursor/mcp.json или .cursor/mcp.json в проекте.",
 "url": "$EXCALIBUR_PUBLIC_SITE_URL/blog/podklyuchenie-mcp-cursor/#config-location"
 },
 {
 "@type": "HowToStep",
 "position": 3,
 "name": "Завершите авторизацию",
 "text": "Пройдите OAuth или введите API key, если сервер запрашивает. Для ручного способа добавьте блок mcpServers с command/args (stdio) или url/headers (облако).",
 "url": "$EXCALIBUR_PUBLIC_SITE_URL/blog/podklyuchenie-mcp-cursor/#manual-json"
 },
 {
 "@type": "HowToStep",
 "position": 4,
 "name": "Сохраните валидный JSON",
 "text": "Проверьте mcp.json валидатором: без висячих запятых, секреты в env или ${env:VAR_NAME}, не в Git.",
 "url": "$EXCALIBUR_PUBLIC_SITE_URL/blog/podklyuchenie-mcp-cursor/#manual-json"
 },
 {
 "@type": "HowToStep",
 "position": 5,
 "name": "Перезапустите Cursor",
 "text": "После правки конфига выполните полный перезапуск Cursor или Command Palette → Reload Window.",
 "url": "$EXCALIBUR_PUBLIC_SITE_URL/blog/podklyuchenie-mcp-cursor/#one-click"
 },
 {
 "@type": "HowToStep",
 "position": 6,
 "name": "Проверьте статус сервера",
 "text": "В Tools & MCP убедитесь, что индикатор сервера активный (не красный). При ошибке откройте Output → MCP Logs.",
 "url": "$EXCALIBUR_PUBLIC_SITE_URL/blog/podklyuchenie-mcp-cursor/#troubleshooting"
 },
 {
 "@type": "HowToStep",
 "position": 7,
