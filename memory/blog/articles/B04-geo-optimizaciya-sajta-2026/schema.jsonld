 "@id": "$EXCALIBUR_PUBLIC_SITE_URL/geo-optimizaciya-sajta-2026/#faq",
 "mainEntity": [
 {
 "@type": "Question",
 "name": "С чего начать geo оптимизацию?",
 "acceptedAnswer": {
 "@type": "Answer",
 "text": "Откройте robots.txt и убедитесь, что AI-боты не заблокированы. Составьте 10 тестовых промптов и прогоните в ChatGPT, Perplexity и Алисе. Добавьте FAQ 5–7 на money-page с ответами до 80 слов и разметкой FAQPage. Это минимум за одну рабочую сессию 60–90 минут."
 }
 },
 {
 "@type": "Question",
 "name": "Чем GEO отличается от SEO?",
 "acceptedAnswer": {
 "@type": "Answer",
 "text": "SEO гонится за позицией и кликом в классической выдаче. GEO – за цитированием в синтезированном ответе нейросети. SEO остаётся фундаментом: без топ-30 органики сложнее попасть в 5 источников Яндекс Нейро. GEO добавляет answer-first, FAQ и Schema."
 }
 },
 {
 "@type": "Question",
 "name": "Нужна ли Schema для GEO?",
 "acceptedAnswer": {
 "@type": "Answer",
 "text": "Да: FAQPage, Article, Organization – минимум 2026. Проверяйте JSON-LD в Rich Results Test."
 }
 },
 {
 "@type": "Question",
 "name": "Как попасть в ответы Яндекс Нейро и Алисы?",
 "acceptedAnswer": {
 "@type": "Answer",
 "text": "Топ-30 органики, answer-first в начале, FAQ, HTML без JS. Яндекс берёт 5 источников; YandexGPT цитирует текст страницы."
 }
 },
 {
 "@type": "Question",
 "name": "Обязателен ли llms.txt?",
 "acceptedAnswer": {
 "@type": "Answer",
 "text": "Нет. Сначала robots.txt, HTML и Schema. llms.txt – опциональная подсказка для LLM-краулеров."
 }
 },
 {
 "@type": "Question",
 "name": "Сколько ждать результат geo оптимизации?",
 "acceptedAnswer": {
 "@type": "Answer",
 "text": "3–6 недель на первые сдвиги после robots/Schema/FAQ; устойчивый SoV – 2–3 месяца замеров."
 }
 },
 {
 "@type": "Question",
 "name": "GEO заменяет SEO?",
 "acceptedAnswer": {
 "@type": "Answer",
 "text": "Нет. Позиции в Google коррелируют с упоминаниями в ChatGPT. Оптимизируйте оба канала."
 }
 }
 ]
 },
