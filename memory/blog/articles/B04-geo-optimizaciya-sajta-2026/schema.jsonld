 "url": "$EXCALIBUR_PUBLIC_SITE_URL/geo-optimizaciya-sajta-2026/#audit-presence"
 },
 {
 "@type": "HowToStep",
 "position": 3,
 "name": "Проверьте HTML-доступность",
 "text": "View-source ключевых URL — основной текст виден без JavaScript. При SPA — SSR, пререндер или статические fallback-блоки.",
 "url": "$EXCALIBUR_PUBLIC_SITE_URL/geo-optimizaciya-sajta-2026/#audit-presence"
 },
 {
 "@type": "HowToStep",
 "position": 4,
 "name": "Перестройте priority-страницы",
