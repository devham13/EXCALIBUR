 "url": "$EXCALIBUR_PUBLIC_SITE_URL/geo-optimizaciya-sajta-2026/#content-structure"
 },
 {
 "@type": "HowToStep",
 "position": 5,
 "name": "Внедрите Schema.org JSON-LD",
 "text": "FAQPage на FAQ-блоках, Article на статьях, Organization и WebSite на главной. Прогоните Rich Results Test.",
 "url": "$EXCALIBUR_PUBLIC_SITE_URL/geo-optimizaciya-sajta-2026/#schema-robots"
 },
 {
 "@type": "HowToStep",
 "position": 6,
 "name": "Обновите sitemap и даты",
