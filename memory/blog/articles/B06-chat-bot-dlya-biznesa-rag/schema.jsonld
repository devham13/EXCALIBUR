    {
      "@type": "FAQPage",
      "@id": "https://mayai.ru/chat-bot-dlya-biznesa-rag/#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Как создать чат-бот для бизнеса без программиста?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Зафиксируйте одну задачу (FAQ или лиды), выберите канал и соберите workflow в n8n или Make: триггер → AI Agent → Vector Store → CRM. При готовом FAQ MVP занимает 3-7 дней; без базы знаний не запускайте - будет галлюцинации."
          }
        },
        {
          "@type": "Question",
          "name": "Чем чат-бот с RAG отличается от конструктора без базы знаний?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Конструктор без RAG отвечает \"из головы\" модели. RAG подтягивает ваши документы перед ответом. Настройте system prompt \"только из контекста\" и эскалацию, если chunk не найден."
          }
        },
        {
          "@type": "Question",
          "name": "ИИ чат-бот для бизнеса бесплатно - реально?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "n8n Community Edition бесплатен, но нужны сервер и оплата API LLM. Make Free даёт 1000 credits/мес. \"Бесплатно без RAG\" - риск выдуманных цен; минимум - vector store и тест-кейсы."
          }
        },
        {
          "@type": "Question",
          "name": "Как подключить чат-бота в Telegram для бизнеса?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "BotFather → токен → Business mode → Telegram Trigger в n8n или модуль в Make → memory по chat_id → 20 тестовых диалогов до рекламы. Проверьте эскалацию на фразу \"оператор\"."
          }
        },
        {
          "@type": "Question",
          "name": "Нужен ли MAX, если уже есть Telegram?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "На MVP - не обязателен. Добавляйте MAX после стабильных FCR/CSAT в Telegram; учитывайте модерацию до 48 рабочих часов и лимит 5 ботов на организацию."
          }
        },
        {
          "@type": "Question",
          "name": "Когда эскалировать диалог оператору?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Нет факта в базе, жалоба, медицина/юридические темы, низкая confidence, триггер-слова. Передавайте полный transcript в CRM и ставьте pause bot для этого chat_id до ответа человека."
          }
        }
      ]
    },
