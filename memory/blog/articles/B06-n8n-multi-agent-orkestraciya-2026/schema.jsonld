      "step": [
        {
          "@type": "HowToStep",
          "position": 1,
          "name": "Prerequisite",
          "text": "Single agent из B02 отвечает в Chat UI. Иначе сначала B02.",
          "url": "https://mayai.ru/blog/n8n-multi-agent-orkestraciya-2026/#build-orchestrator"
        },
        {
          "@type": "HowToStep",
          "position": 2,
          "name": "Orchestrator",
          "text": "Chat Trigger → AI Agent → Chat Model. В System Message перечислите sub-agents по зонам ответственности.",
          "url": "https://mayai.ru/blog/n8n-multi-agent-orkestraciya-2026/#build-orchestrator"
        },
        {
          "@type": "HowToStep",
          "position": 3,
          "name": "Specialists (MVP)",
          "text": "2-3 AI Agent Tool sub-nodes: своя модель, prompt, 1-3 tools каждый.",
          "url": "https://mayai.ru/blog/n8n-multi-agent-orkestraciya-2026/#build-orchestrator"
        },
        {
          "@type": "HowToStep",
          "position": 4,
          "name": "Tool description",
          "text": "2-4 предложения: что делает, вход, выход, когда не вызывать. Без description orchestrator не делегирует.",
          "url": "https://mayai.ru/blog/n8n-multi-agent-orkestraciya-2026/#build-orchestrator"
        },
        {
          "@type": "HowToStep",
          "position": 5,
          "name": "JSON task envelope",
          "text": "Структурированный контекст между agents: task, context, expected_output в JSON.",
          "url": "https://mayai.ru/blog/n8n-multi-agent-orkestraciya-2026/#build-orchestrator"
        },
        {
          "@type": "HowToStep",
          "position": 6,
          "name": "Prod",
          "text": "Call n8n Workflow Tool вместо embedded AI Agent Tool - отдельный workflow на worker.",
          "url": "https://mayai.ru/blog/n8n-multi-agent-orkestraciya-2026/#build-orchestrator"
        },
        {
          "@type": "HowToStep",
          "position": 7,
          "name": "Лимит tools",
          "text": "Не больше 5 на agent; при 15 tools и использовании ~3 - split на focused agents (n8n playbook).",
          "url": "https://mayai.ru/blog/n8n-multi-agent-orkestraciya-2026/#build-orchestrator"
        },
        {
          "@type": "HowToStep",
          "position": 8,
          "name": "Continue on Error",
          "text": "Включите Continue on Error на внешних API tools.",
          "url": "https://mayai.ru/blog/n8n-multi-agent-orkestraciya-2026/#build-orchestrator"
        }
      ]
