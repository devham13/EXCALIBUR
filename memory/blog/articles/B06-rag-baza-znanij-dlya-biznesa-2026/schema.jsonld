 "@id": "$EXCALIBUR_PUBLIC_SITE_URL/blog/rag-baza-znanij-dlya-biznesa-2026/#faq",
 "mainEntity": [
 {
 "@type": "Question",
 "name": "Как настроить RAG базу знаний с нуля?",
 "acceptedAnswer": {
 "@type": "Answer",
 "text": "Соберите 20-30 эталонных вопросов, очистите узкий корпус, настройте ingestion в n8n (splitter → embeddings → Qdrant или pgvector), подключите AI Agent с tool retrieval, прогоните golden set и только потом открывайте бот."
 }
 },
 {
 "@type": "Question",
 "name": "Какой размер чанка выбрать для RAG?",
 "acceptedAnswer": {
 "@type": "Answer",
 "text": "Старт: 400-512 токенов, overlap 10-20%. Для длинных регламентов - 500-1000 tok. Режьте по заголовкам секций, не только по длине - так точнее попадание в нужный пункт."
 }
 },
 {
 "@type": "Question",
 "name": "Чем RAG отличается от обычного ChatGPT?",
 "acceptedAnswer": {
 "@type": "Answer",
 "text": "ChatGPT не видит ваши PDF и Confluence. RAG перед ответом ищет фрагменты в индексе и показывает цитату - меньше выдумок про ваши цены и правила."
 }
 },
 {
 "@type": "Question",
 "name": "Qdrant или pgvector для корпоративной базы?",
 "acceptedAnswer": {
 "@type": "Answer",
 "text": "Qdrant, если нужен отдельный search-сервис с native hybrid и фильтрами по metadata. pgvector, если PostgreSQL уже хранит CRM-данные и вы не хотите новый сервер."
 }
 },
 {
 "@type": "Question",
 "name": "Зачем reranker, если есть vector search?",
 "acceptedAnswer": {
 "@type": "Answer",
 "text": "Vector ловит смысл, но промахивается по артикулам и кодам. Reranker пересортировывает 20-50 кандидатов и оставляет 4-6 лучших - без него precision заметно падает."
 }
 },
 {
 "@type": "Question",
 "name": "Как проверить RAG перед запуском?",
 "acceptedAnswer": {
 "@type": "Answer",
 "text": "Golden set 20-30 Q&A, прогон через pipeline, метрики faithfulness и context recall (RAGAS или вручную). Порог ~0.9; при провале меняйте chunk size и overlap, не модель."
 }
 },
 {
 "@type": "Question",
 "name": "Что делать, если бот ответил неправильно?",
 "acceptedAnswer": {
 "@type": "Answer",
 "text": "Кнопка \"сообщить об ошибке\", сохраните chunk IDs из лога, переиндексируйте документ, передайте диалог менеджеру - не закрывайте тикет автоматически."
 }
 }
 ]
 }
 ]
